rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper functions — powered by Custom Claims (JWT token)
    // =========================================================================

    /// Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Get the app UID (personal number) from custom claims
    function myAppUid() {
      return request.auth.token.appUid;
    }

    /// Get the role from custom claims
    function myRole() {
      return request.auth.token.role;
    }

    /// Check if the current user is a developer or admin
    function isDeveloperOrAdmin() {
      let r = request.auth.token.role;
      return r == 'developer' || r == 'admin';
    }

    /// Check if the given unitId is within the current user's unit scope
    /// hasFullScope=true for developers/admins OR large-scope commanders (>800 bytes)
    /// For large-scope non-admin commanders, fallback to auth_mapping read (rare)
    function isInUnitScope(unitId) {
      return (request.auth.token.role in ['developer', 'admin']) ||
        (!request.auth.token.hasFullScope && unitId in request.auth.token.unitScope) ||
        (request.auth.token.hasFullScope &&
         unitId in get(/databases/$(database)/documents/auth_mapping/$(request.auth.uid)).data.allowedUnitScopeIds);
    }

    /// Check if the current user is a participant in the given navigation doc
    function isParticipant(navDoc) {
      return myAppUid() in navDoc.data.participants;
    }

    /// Self-check: is this my own user doc?
    function isSelf(personalNumber) {
      return myAppUid() == personalNumber;
    }

    /// Create: user must NOT include role or isApproved fields
    function noPrivilegeFieldsOnCreate() {
      return !('role' in request.resource.data)
             && !('isApproved' in request.resource.data);
    }

    /// Update: user must NOT change role or isApproved fields
    function noPrivilegeFieldChanges() {
      return !request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasAny(['role', 'isApproved']);
    }

    /// Commander approval: only isApproved/role/updatedAt changed, can't set admin roles
    /// Value must be true (approve) or false (reject) — not "pending" or other
    function validCommanderApproval() {
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['isApproved', 'role', 'updatedAt'])
             && (request.resource.data.isApproved == true || request.resource.data.isApproved == false)
             && request.resource.data.get('role', 'navigator') != 'unit_admin'
             && request.resource.data.get('role', 'navigator') != 'admin'
             && request.resource.data.get('role', 'navigator') != 'developer';
    }

    /// Unit admin approval: only isApproved/role/updatedAt changed, can't set developer
    /// Value must be true (approve) or false (reject)
    function validAdminApproval() {
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['isApproved', 'role', 'updatedAt'])
             && (request.resource.data.isApproved == true || request.resource.data.isApproved == false)
             && request.resource.data.get('role', 'navigator') != 'developer';
    }

    /// Removing user from unit: unitId deleted/nullified
    function removingFromUnit() {
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['unitId', 'isApproved', 'role', 'updatedAt'])
             && request.resource.data.get('unitId', null) == null;
    }

    /// Adding user to unit: unitId set to value, isApproved set to true
    function validAddToUnit() {
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['unitId', 'isApproved', 'role', 'updatedAt'])
             && request.resource.data.get('unitId', null) != null
             && request.resource.data.get('isApproved', false) == true
             && request.resource.data.get('role', 'navigator') != 'developer'
             && request.resource.data.get('role', 'navigator') != 'admin';
    }

    // =========================================================================
    // /auth_mapping/{uid} -- Firebase Auth UID -> App user mapping
    // =========================================================================
    match /auth_mapping/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && request.auth.uid == uid &&
        request.resource.data.role ==
          get(/databases/$(database)/documents/users/$(request.resource.data.appUid)).data.get('role', 'navigator');
    }

    // =========================================================================
    // /email_codes/{docId} -- Email OTP codes (server-only)
    // =========================================================================
    match /email_codes/{docId} {
      allow read, write: if false;
    }

    // =========================================================================
    // /mail/{docId} -- Firebase Trigger Email extension (server-only)
    // =========================================================================
    match /mail/{docId} {
      allow read, write: if false;
    }

    // =========================================================================
    // /email_lookup/{email} -- Email-to-UID mapping for login
    // =========================================================================
    match /email_lookup/{email} {
      allow read, write: if isAuthenticated();
    }

    // =========================================================================
    // /phone_lookup/{phoneNumber} -- Phone-to-UID mapping for login
    // =========================================================================
    match /phone_lookup/{phoneNumber} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // =========================================================================
    // /users/{personalNumber} -- User profiles
    // =========================================================================
    match /users/{personalNumber} {

      // ── Developer/Admin — full access ──
      allow read, write: if isDeveloperOrAdmin();

      // ── GET — any authenticated (login lookup by personal number) ──
      allow get: if isAuthenticated();

      // ── LIST — unit scope (SyncManager + PendingApprovalsScreen) ──
      allow list: if isAuthenticated() && isInUnitScope(resource.data.unitId);

      // ── CREATE — self only, no privilege fields ──
      allow create: if isAuthenticated()
                    && isSelf(personalNumber)
                    && noPrivilegeFieldsOnCreate();

      // ── UPDATE self — no privilege field changes ──
      allow update: if isSelf(personalNumber)
                    && noPrivilegeFieldChanges();

      // ── CANCEL OWN REQUEST — remove self from unit ──
      allow update: if isSelf(personalNumber)
                    && removingFromUnit();

      // ── JOIN / RE-REQUEST — user requests to join a unit ──
      allow update: if isSelf(personalNumber)
                    && resource.data.get('isApproved', null) != true
                    && request.resource.data.get('isApproved', null) == 'pending'
                    && !request.resource.data.diff(resource.data)
                          .affectedKeys().hasAny(['role']);

      // ── APPROVAL — commander (can't assign unit_admin/admin/developer) ──
      allow update: if myRole() == 'commander'
                    && isInUnitScope(resource.data.unitId)
                    && validCommanderApproval();

      // ── APPROVAL — unit_admin (can't assign developer) ──
      allow update: if myRole() == 'unit_admin'
                    && isInUnitScope(resource.data.unitId)
                    && validAdminApproval();

      // ── REMOVE FROM UNIT — commander/unit_admin ──
      allow update: if myRole() in ['commander', 'unit_admin']
                    && isInUnitScope(resource.data.unitId)
                    && removingFromUnit();

      // ── ADD TO UNIT — commander/unit_admin adds user directly ──
      allow update: if myRole() in ['commander', 'unit_admin']
                    && isInUnitScope(request.resource.data.unitId)
                    && validAddToUnit();

      // ── DELETE — developer/admin only (covered by first rule) ──
    }

    // =========================================================================
    // /units/{unitId} -- Organizational units
    // =========================================================================
    match /units/{unitId} {
      // Any authenticated user can read units (needed for onboarding ChooseUnitScreen)
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() &&
        (isDeveloperOrAdmin() || isInUnitScope(unitId));

      match /members/{memberId} {
        allow read, write: if isAuthenticated() &&
          (isDeveloperOrAdmin() || isInUnitScope(unitId));
      }
    }

    // =========================================================================
    // /areas/{areaId} -- Geographic areas (shared, all authenticated users)
    // =========================================================================
    match /areas/{areaId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();

      match /layers_nz/{checkpointId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated();
      }

      match /layers_nb/{safetyPointId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated();
      }

      match /layers_gg/{boundaryId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated();
      }

      match /layers_ba/{clusterId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated();
      }
    }

    // =========================================================================
    // Flat legacy layer collections (backward compatibility)
    // =========================================================================
    match /layers_nz/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /layers_nb/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /layers_gg/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /layers_ba/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // =========================================================================
    // /navigation_trees/{treeId} -- Navigation tree definitions
    // =========================================================================
    match /navigation_trees/{treeId} {
      allow read: if isAuthenticated() &&
        (isDeveloperOrAdmin() || isInUnitScope(resource.data.unitId));
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (isDeveloperOrAdmin() || isInUnitScope(resource.data.unitId));

      match /frameworks/{frameworkId} {
        allow read, write: if isAuthenticated();

        match /sub_frameworks/{subFrameworkId} {
          allow read, write: if isAuthenticated();
        }
      }
    }

    // Legacy collection name
    match /navigator_trees/{treeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // =========================================================================
    // /navigations/{navId} -- Navigation events (participant-scoped)
    // =========================================================================
    match /navigations/{navId} {
      allow read: if isAuthenticated() &&
        (isDeveloperOrAdmin() || isParticipant(resource));
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (isDeveloperOrAdmin() || isParticipant(resource));

      // All subcollections inherit parent navigation membership
      match /{subcollection}/{docId} {
        allow read: if isAuthenticated() &&
          (isDeveloperOrAdmin() ||
           myAppUid() in get(/databases/$(database)/documents/navigations/$(navId)).data.participants);
        allow create, update, delete: if isAuthenticated() &&
          (isDeveloperOrAdmin() ||
           myAppUid() in get(/databases/$(database)/documents/navigations/$(navId)).data.participants);
      }
    }

    // =========================================================================
    // /rooms/{roomId} -- Voice message rooms (PTT / Walkie Talkie)
    // roomId = navigationId, so check navigation participants
    // =========================================================================
    match /rooms/{roomId} {
      allow read, write: if isAuthenticated() &&
        (isDeveloperOrAdmin() ||
         myAppUid() in get(/databases/$(database)/documents/navigations/$(roomId)).data.participants);

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() &&
          (isDeveloperOrAdmin() ||
           myAppUid() in get(/databases/$(database)/documents/navigations/$(roomId)).data.participants);
      }
    }

    // =========================================================================
    // /solo_quiz_questions/{questionId} -- Quiz questions (read-only for users)
    // /solo_quiz_config/{docId} -- Quiz configuration
    // =========================================================================
    match /solo_quiz_questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isDeveloperOrAdmin();
    }

    match /solo_quiz_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isDeveloperOrAdmin();
    }

    // =========================================================================
    // Legacy flat collections (backward compatibility)
    // =========================================================================
    match /navigation_tracks/{trackId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /navigation_approval/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // =========================================================================
    // /commander_tokens/{uid} -- Active commander FCM tokens
    // =========================================================================
    match /commander_tokens/{uid} {
      allow read: if isAuthenticated() && isDeveloperOrAdmin();
      allow create, update: if isAuthenticated() && myAppUid() == uid;
      allow delete: if isAuthenticated() && (myAppUid() == uid || isDeveloperOrAdmin());
    }

    // =========================================================================
    // /sync_metadata/{userId} -- Per-user sync state
    // =========================================================================
    match /sync_metadata/{uid} {
      allow read, write: if isAuthenticated();
    }
  }
}
